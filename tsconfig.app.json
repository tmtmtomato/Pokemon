{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./build",
    "declaration": false
  },
  "include": ["app/**/*", "src/**/*", "tracker/**/*", "home-data/viewer/**/*", "home-data/viewer-teams/**/*", "home-data/viewer-singles/**/*", "home-data/viewer-matchup/**/*", "home-data/viewer-ml/**/*", "home-data/types/**/*"]
}
