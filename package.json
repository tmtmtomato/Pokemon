{
  "name": "pokemon-champions-calc",
  "version": "0.1.0",
  "description": "Damage calculator engine for Pokemon Champions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "dev:tracker": "vite --open /index-tracker.html",
    "build:calc": "cross-env VITE_ENTRY=calc vite build",
    "build:tracker": "cross-env VITE_ENTRY=tracker vite build",
    "build:ui": "cross-env VITE_ENTRY=calc vite build && cross-env VITE_ENTRY=tracker vite build",
    "build:meta": "cross-env VITE_ENTRY=meta vite build",
    "build:teams": "cross-env VITE_ENTRY=teams vite build",
    "preview": "vite preview",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smogon": "vitest run tests/cross-validation-smogon.test.ts",
    "test:pokesol": "tsx scripts/pokesol-compare.mjs",
    "test:crossval": "vitest run tests/cross-validation-smogon.test.ts && tsx scripts/pokesol-compare.mjs",
    "home:pikalytics": "tsx home-data/pikalytics/run-all.ts",
    "home:vgcpast:enum": "tsx home-data/vgcpast/enumerate.ts",
    "home:vgcpast": "tsx home-data/vgcpast/run-all.ts",
    "home:analyze": "tsx home-data/analyzer/run-all.ts",
    "home:teams": "tsx home-data/analyzer/team-aggregate.ts",
    "home:singles": "tsx home-data/analyzer/singles-ranking.ts",
    "build:singles": "cross-env VITE_ENTRY=singles vite build",
    "home:matchup": "tsx home-data/analyzer/team-matchup.ts",
    "build:matchup": "cross-env VITE_ENTRY=matchup vite build",
    "meta:ranking": "node home-data/scripts/compute-meta-ranking.mjs",
    "meta:firepower": "node home-data/scripts/compute-firepower-ranking.mjs",
    "build:firepower": "node home-data/scripts/compute-firepower-ranking.mjs && cross-env VITE_ENTRY=firepower vite build",
    "build:moves": "node home-data/scripts/compute-meta-ranking.mjs && cross-env VITE_ENTRY=moves vite build",
    "build:ml": "cross-env VITE_ENTRY=ml vite build",
    "ml:extract": "tsx home-data/ml/pipeline/extract-training.ts",
    "ml:split": "tsx home-data/ml/pipeline/split-data.ts",
    "ml:team-eval": "tsx home-data/ml/models/team-eval/train.ts",
    "ml:selection": "tsx home-data/ml/models/selection/train.ts",
    "ml:move-advisor": "tsx home-data/ml/models/move-advisor/train.ts",
    "ml:all": "npm run ml:extract && npm run ml:split && npm run ml:team-eval && npm run ml:selection && npm run ml:move-advisor",
    "pipeline": "tsx scripts/daily-pipeline.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.1.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@smogon/calc": "^0.11.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
